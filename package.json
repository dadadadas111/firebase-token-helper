{
  "name": "firebase-token-helper",
  "version": "0.1.3",
  "description": "CLI + TUI tool to generate Firebase ID tokens and set custom claims — no frontend login required",
  "main": "src/commands/getToken.js",
  "bin": {
    "ftk": "index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node index.js",
    "build": "npx @yao-pkg/pkg index.js --targets node18-win-x64,node18-linux-x64,node18-macos-x64,node18-macos-arm64 --output dist/ftk",
    "build:win": "npx @yao-pkg/pkg index.js --targets node18-win-x64 --output dist/ftk-win.exe",
    "build:linux": "npx @yao-pkg/pkg index.js --targets node18-linux-x64 --output dist/ftk-linux",
    "build:macos": "npx @yao-pkg/pkg index.js --targets node18-macos-x64,node18-macos-arm64 --output dist/ftk-macos"
  },
  "pkg": {
    "scripts": [
      "src/**/*.js"
    ],
    "assets": [],
    "targets": [
      "node18-win-x64",
      "node18-linux-x64",
      "node18-macos-x64",
      "node18-macos-arm64"
    ]
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "dotenv": "^16.3.1",
    "firebase-admin": "^11.10.0",
    "yargs": "^17.7.2"
  }
}
